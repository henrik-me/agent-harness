{
  "$schema-note": "Body shape for PUT /repos/{owner}/{repo}/rulesets/{ruleset_id} (Repository Rulesets API). Authored and applied during CS15a public flip. See https://docs.github.com/en/rest/repos/rules. Decision #18 + #23 in harness-cs-plan.md.",
  "name": "main-protection",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": ["squash"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "validate" },
          { "context": "validate-schemas" },
          { "context": "smoke / harness-lint" },
          { "context": "secret-scan" },
          { "context": "npm-pack-dry-run" },
          { "context": "commit-trailers" },
          { "context": "pr-body" },
          { "context": "check-workflow-pins" },
          { "context": "check-public-artifact" }
        ]
      }
    }
  ]
}
